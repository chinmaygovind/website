# Copy to kot/.env on the box. Loaded by deploy/kot.service.

# Port the eventlet gunicorn worker binds to (nginx proxies kot.cgovind.com here).
PORT=5004

# MUST match Ticket to Ride's SECRET_KEY (copy it from ttr/.env). Together with
# SESSION_COOKIE_DOMAIN below, this makes a login on any cgovind.com game valid
# on all of them.
SECRET_KEY=

# Share TTR's SQLite database so the accounts (users table) are the same. On the
# prod box TTR runs from its own clone at /home/ubuntu/TicketToRide, so its db is:
DATABASE_URL=sqlite:////home/ubuntu/TicketToRide/instance/tickettoride.db

# Cross-subdomain single sign-on. Set on kot/.env, ers/.env and ttr/.env in prod.
# Leave unset for local dev (localhost shares cookies across ports already).
SESSION_COOKIE_DOMAIN=.cgovind.com
SESSION_COOKIE_SECURE=1

# Public URL (used in any links).
SITE_URL=https://kot.cgovind.com

# Bump to bust cached CSS/JS after a deploy (optional).
ASSET_VERSION=1
