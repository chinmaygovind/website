# Copy to .env and adjust. Loaded by the systemd unit (deploy/website.service).

# Port the Flask/gunicorn server binds to (nginx proxies to it).
PORT=5002

# Where /ttr and the Wii "TTR" channel redirect. TTR runs as its own service
# (the ttr/ submodule); point this at wherever it's reachable, e.g.
#   local dev:   http://localhost:5001
#   production:  https://ttr.cgovind.com
TTR_URL=https://ttr.cgovind.com

# Where /ers redirects. Egyptian Rat Screw runs as its own service (website/ers).
#   local dev:   http://localhost:5003
#   production:  https://ers.cgovind.com
ERS_URL=https://ers.cgovind.com

# Server-side key for the roll game's NPC dialog (Gemini). The browser calls
# /api/roll/gemini and the server adds this key, so it never reaches the client.
# Leave blank to disable the dialog feature. Get one from Google AI Studio and
# restrict it (referrer/API restrictions) in the Google Cloud console.
GEMINI_API_KEY=
