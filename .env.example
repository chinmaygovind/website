# Copy to .env and adjust. Loaded by the systemd unit (deploy/website.service).

# Port the Flask/gunicorn server binds to (nginx proxies to it).
PORT=5002

# Where /ttr and the Wii "TTR" channel redirect. TTR runs as its own service
# (the ttr/ submodule); point this at wherever it's reachable, e.g.
#   local dev:   http://localhost:5001
#   production:  https://ttr.your-domain.com   (or the TTR box's IP)
TTR_URL=http://52.54.184.133
